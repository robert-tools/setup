{
    "name": "@robert.tools/setup",
    "version": "1.0.0",
    "description": "A couple of tools to initialize and update a repo.",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js"
    },
    "bin": {
        "robert-tools-init": "./dist/init.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "run": "tsx src/apps/index.ts",
        "test": "jest --coverage --runInBand --verbose",
        "lint": "eslint .",
        "check": "npm run lint && npm test && npm run build",
        "prepublishOnly": "npm run check"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/robert-tools/setup.git"
    },
    "bugs": {
        "url": "https://github.com/robert-tools/setup/issues"
    },
    "homepage": "https://github.com/robert-tools/setup#readme",
    "keywords": [
        "typescript",
        "node",
        "setup",
        "robert.tools"
    ],
    "author": "Robert Willemelis",
    "license": "MIT",
    "engines": {
        "node": ">=22"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/mock-fs": "^4.13.4",
        "@types/node": "^24.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.6.2",
        "mock-fs": "^5.5.0",
        "ts-jest": "^29.4.0",
        "tsx": "^4.22.3",
        "typescript": "^5.9.0"
    },
    "dependencies": {
        "@robert.tools/cmd": "^1.0.0",
        "@robert.tools/fs": "^1.1.2",
        "@robert.tools/log": "^1.0.0"
    }
}
