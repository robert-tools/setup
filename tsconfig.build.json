{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "isolatedModules": false,
        "module": "CommonJS",
        "moduleResolution": "Node",
        "declaration": true,
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": "src"
    },
    "exclude": [
        "src/**/*.spec.ts",
        "src/**/*.test.ts"
    ]
}
